];

const contact: ContactProps = {
  email: "example@example.com",
  address: "123 Street, City, Country",
  phone: "+1234567890",
};

// Your profile (sidebar + page metadata).
// • github: your GitHub username — this DRIVES the auto-generated Projects
//   section (it fetches your public repos).
// • avatar: any image URL. 
// • resumeLink: "/CV.pdf" uses the LaTeX→PDF build (see README). Can also be
//   any external URL.
// • about: supports "\n" line breaks and a little inline HTML, e.g.
//   "<span class='text-emerald-500'>highlighted text</span>".
const user: UserProps = {
  name: "John Doe",
  github: "username",
  avatar: "https://github.com/username.png",
  title: "Frontend Developer",
  resumeLink: "/CV.pdf",
  about:
    "Lorem ipsum dolor sit amet, consectetur adipiscing elit. " +
    "Sed commodo odio ut turpis condimentum.\n" +
    "Currently working as a <span class='text-emerald-500'>Developer</span>.",
};

// Repo names to HIDE from the auto-generated Projects section.
const ignoreProjects: string[] = ["dotfiles", "my-config-repo"];

// Extra projects — anything NOT on GitHub (designs, hardware, writing…).

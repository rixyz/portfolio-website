// -----------------------------------------------------------------------------
// Social links. `name` is used BOTH for the icon (Font Awesome brand:
// `fab fa-<name>`) and the accessible label, so use known brand slugs:
// "github", "linkedin", "twitter", "instagram", ...
// -----------------------------------------------------------------------------
const socials: SocialProps[] = [
  { name: "github", url: "https://github.com/username" },
  { name: "linkedin", url: "https://www.linkedin.com/in/username" },
];

// Skills grid. `icon` is a Font Awesome class string (loaded via CDN in
// index.html): "fab fa-react" (brand), "fas fa-database" (solid), etc.
// Browse icons at https://fontawesome.com/icons
const skills: SkillProps[] = [
  { name: "HTML", icon: "fab fa-html5" },
  { name: "CSS", icon: "fab fa-css3-alt" },
  { name: "JavaScript", icon: "fab fa-js" },
